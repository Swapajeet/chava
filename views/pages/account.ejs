<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>chava</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>

.profile-header{
height:80px;
background:linear-gradient(45deg,#3b82f6,#6366f1);
border-top-left-radius:10px;
border-top-right-radius:10px;
}

.profile-img{
width:90px;
margin-top:-45px;
border-radius:50%;
border:4px solid white;
}

.profile-card{
border-radius:10px;
}

.membership-card{
border-radius:10px;
transition:0.3s;
}

.membership-card:hover{
transform:translateY(-3px);
box-shadow:0 10px 25px rgba(0,0,0,0.1);
}
.badge{
      color:white;
}

</style>

</head>

<body>

<div class="container mt-5">
<div class="row g-4">

<!-- LEFT PROFILE CARD -->

<div class="col-md-4">

<div class="card shadow border-0 profile-card">

<div class="profile-header"></div>

<div class="card-body text-center">

<img src="<%= foundstudent.image.url %>" class="profile-img">

<h4 class="mt-3 fw-bold">
<%= foundstudent.fullName %>
</h4>

<span class="badge bg-success px-3 py-2">
<%= foundstudent.status %>
</span>

<p class="text-muted mt-2">
<i class="fa fa-map-marker-alt"></i>
<%= foundstudent.city %>
</p>

<hr>

<p class="mb-1">
📞 <%= foundstudent.mobile %>
</p>

<p class="text-muted">
📅 Joined <%= foundstudent.joinDate.toDateString() %>
</p>
 <form action="/students/status/<%= foundstudent._id %>?_method=PUT" method="POST">

<div class="form-check form-switch">

<input 
class="form-check-input" 
type="checkbox" 
name="status"
onchange="this.form.submit()"
<%= foundstudent.status === "Active" ? "checked" : "" %>
>

<label class="form-check-label">
<%= foundstudent.status %>
</label>

</div>

</form>


<a href="https://wa.me/<%= foundstudent.mobile %>"
class="btn btn-success w-100 mt-2">
💬 Message on WhatsApp
</a>

</div>
</div>

<!-- CURRENT MEMBERSHIP -->

<div class="card mt-4 shadow border-0">

<div class="card-body">

<h5 class="text-danger fw-bold mb-3">
Current Membership
</h5>

<p class="mb-2">
    <% if(foundstudent.Membership.length !== 0){ %>
        <span class="text-muted">No active membership</span>
<b>Plan :<%=foundstudent.Membership[0].planType %></b>
</p>


<p class="mb-0">
<b>Expires : <%=foundstudent.Membership[0].endDate.toDateString()%></b>
</p>
<%}%>
</div>
</div>

</div>


<!-- RIGHT SIDE -->

<div class="col-md-8">

<div class="d-flex justify-content-between mb-4">

<a href="/students/<%= foundstudent._id %>/membership/form" class="btn btn-primary px-4" >New Membership</a>

<button class="btn btn-outline-dark px-4">
💰 Record Payment
</button>

</div>
<h4 class="fw-bold mb-4">
    Membership History
</h4>

<% for(let membership of foundstudent.Membership){ %>

<div class="card shadow-sm border-0 mb-4 membership-card col-6">
    
    <div class="card-body">

        <!-- Header -->
        <div class="d-flex justify-content-between align-items-center mb-2 ">

            <div>
                <h5 class="fw-bold mb-0">
                    <%= membership.planType %>
                </h5>

                <small class="text-muted">
                    <%= membership.startDate.toDateString() %> -
                    <%= membership.endDate.toDateString() %>
                </small>
            </div>

                  
                </div>

            <% if(!membership.Payment) { %>
            <span class="badge bg-primary px-3 py-2">
                <a href="/membership/<%= membership._id %>/payment" class="btn text-white">Pay</a>
            </span>
            <% } %>

        </div>

        <hr>

        <!-- Dates -->
        <p class="text-muted mb-0">
            <strong>Start Date:</strong> 
            <%= membership.startDate.toDateString() %>

            <br>

            <strong>End Date:</strong> 
            <%= membership.endDate.toDateString() %>
        </p>

    </div>

</div>

<% } %>

<b>Payments</b>


<p class="text-muted">
No payments recorded yet.
</p>

</div>

</div>

</div>

</div>
</div>

</body>
</html>