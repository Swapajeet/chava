<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<title>Membership Form</title>

<style>

body{
    background: #f4f6f9;
    font-family: 'Segoe UI', sans-serif;
}

.membership-card{
    max-width: 500px;
    margin: 80px auto;
    background: white;
    border-radius: 12px;
    box-shadow: 0 5px 20px rgba(0,0,0,0.08);
}

.membership-header{
    background: #0d6efd;
    color: white;
    padding: 18px;
    border-radius: 12px 12px 0 0;
    font-size: 20px;
    font-weight: 600;
    text-align: center;
}

.form-control, .form-select{
    border-radius: 8px;
}

.btn-create{
    background:#0d6efd;
    border:none;
    padding:10px;
    font-weight:500;
}

.btn-create:hover{
    background:#0b5ed7;
}

</style>

</head>
<body>
<div class="membership-card">

<div class="membership-header">
Create Membership
</div>

<div class="p-4">

<form action="/students/<%= meberstudent._id %>/membership" method="POST">

<!-- Plan -->
<div class="mb-3">
<label class="form-label">Plan Type</label>
<select name="membership[planType]" class="form-select">
<option value="1 Month">1 Month</option>
<option value="3 Months">3 Months</option>
<option value="6 Months">6 Months</option>
<option value="12 Months">12 Months</option>
</select>
</div>

<!-- Dates -->
<div class="row">
<div class="col-md-6 mb-3">
<label class="form-label">Start Date</label>
<input type="date" name="membership[startDate]" class="form-control" required>
</div>

<div class="col-md-6 mb-3">
<label class="form-label">End Date</label>
<input type="date" name="membership[endDate]" class="form-control" required>
</div>
</div>

<!-- Fee -->
<div class="mb-3">
<label class="form-label">Total Fee Amount (₹)</label>
<input type="number" name="membership[totalFee]" class="form-control" placeholder="Enter Amount" required>
</div>

<button type="submit" class="btn btn-create w-100">
Create Membership
</button>

</form>

</div>
</div>


</body>
</html>