<style>

/* Clean Modal */
#paymentModal .modal-content{
  border-radius:16px;
  border:none;
  box-shadow:0 8px 30px rgba(0,0,0,0.12);
}

/* Header */
#paymentModal .modal-header{
  background:white;
  border-bottom:1px solid #eee;
  padding:16px 20px;
}

#paymentModal .modal-title{
  font-size:16px;
  font-weight:600;
  color:#111;
}

/* Body */
#paymentModal .modal-body{
  padding:20px;
}

/* Labels */
#paymentModal label{
  font-size:12px;
  font-weight:600;
  color:#6c757d;
  margin-bottom:6px;
}

/* Inputs */
#paymentModal .form-control{
  border-radius:10px;
  padding:10px 12px;
  border:1px solid #ddd;
  font-size:14px;
  transition:0.2s;
}

#paymentModal .form-control:focus{
  border-color:#0d6efd;
  box-shadow:none;
}

/* Button */
#paymentModal .btn-primary{
  border-radius:10px;
  font-size:14px;
  font-weight:600;
  padding:10px;
  background:#0d6efd;
  border:none;
}

#paymentModal .btn-primary:hover{
  background:#0b5ed7;
}

/* Footer */
#paymentModal .modal-footer{
  border-top:1px solid #eee;
  padding:16px 20px;
}

</style>

<!-- MODAL -->
<div class="modal fade" id="paymentModal" tabindex="-1">
<div class="modal-dialog modal-dialog-centered">
<div class="modal-content">

<!-- Header -->
<div class="modal-header">
<h5 class="modal-title">Record Payment</h5>
<button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<form id="paymentForm" action="/membership/<%= meberstudent._id %>" method="POST">

<div class="modal-body">

<div class="mb-3">
<label>Amount (₹)</label>
<input type="number" name="payment[amount]" class="form-control" placeholder="Enter amount" required>
</div>

<div class="mb-3">
<label>Payment Date</label>
<input type="date" name="payment[paymentDate]" class="form-control" required>
</div>

<div class="mb-3">
<label>Notes</label>
<input type="text" name="payment[notes]" class="form-control" placeholder="Cash / UPI / Card">
</div>

</div>

<div class="modal-footer">
<button type="submit" id="payBtn" class="btn btn-primary w-100">
Save Payment
</button>
</div>

</form>

</div>
</div>
</div>

<script>
const form = document.getElementById("paymentForm");
const btn = document.getElementById("payBtn");

form.addEventListener("submit", function () {
  btn.disabled = true;
  btn.innerText = "Saving...";
});
</script>