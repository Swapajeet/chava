
<style>

/* Modal Card */
#paymentModal .modal-content{
border-radius:20px;
overflow:hidden;
border:none;
box-shadow:0 10px 30px rgba(0,0,0,0.15);
}

/* Header */
#paymentModal .modal-header{
background:linear-gradient(135deg,#0d6efd,#4da3ff);
color:white;
border-bottom:none;
}

/* Labels */
#paymentModal label{
font-size:14px;
color:#0d6efd;
font-weight:600;
}

/* Inputs */
#paymentModal .form-control{
border-radius:12px;
padding:12px;
transition:0.3s;
border:1px solid #cfe2ff;
}

#paymentModal .form-control:focus{
border-color:#0d6efd;
box-shadow:0 0 8px rgba(13,110,253,0.3);
}

/* Button */
#paymentModal .btn-primary{
border-radius:12px;
font-weight:600;
transition:0.3s;
}

#paymentModal .btn-primary:hover{
transform:translateY(-2px);
box-shadow:0 6px 15px rgba(0,0,0,0.15);
}

</style>
<!-- Record Payment Modal -->
<div class="modal fade" id="paymentModal" tabindex="-1">
<div class="modal-dialog modal-dialog-centered">
<div class="modal-content shadow-lg border-0 rounded-4">

<!-- Header -->
<div class="modal-header bg-primary text-white">
<h5 class="modal-title">💳 Record Payment</h5>
<button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
</div>

<form action="/membership/<%= meberstudent._id %>" method="POST">

<div class="modal-body p-4 bg-light">

<!-- Amount -->
<div class="mb-3">
<label class="form-label fw-semibold text-primary">Amount (₹)</label>
<input type="number" name="payment[amount]" class="form-control form-control-lg border-primary" placeholder="Enter amount" required>
</div>

<!-- Payment Date -->
<div class="mb-3">
<label class="form-label fw-semibold text-primary">Payment Date</label>
<input type="date" name="payment[paymentDate]" class="form-control form-control-lg border-primary" required>
</div>

<!-- Notes -->
<div class="mb-3">
<label class="form-label fw-semibold text-primary">Notes</label>
<input type="text" name="payment[notes]" class="form-control form-control-lg border-primary" placeholder="Cash / UPI / Card">
</div>

</div>

<div class="modal-footer border-0 px-4 pb-4 bg-white">
<button type="submit" class="btn btn-primary w-100 btn-lg shadow-sm">
💰 Record Payment
</button>
</div>

</form>

</div>
</div>
</div>