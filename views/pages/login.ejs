<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CHHAVA Gym Login</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
background:#f3f4f6;
height:100vh;
display:flex;
align-items:center;
justify-content:center;
font-family:Arial;
}

/* card */

.login-card{
background:white;
width:420px;
padding:40px;
border-radius:15px;
box-shadow:0 10px 30px rgba(0,0,0,0.1);
}

/* logo box */

.logo-box{
width:10px;
height:20px;
background:#2f5fd7;
border-radius:15px;
display:flex;
align-items:center;
justify-content:center;
margin:auto;
color:white;
font-size:30px;
box-shadow:0 5px 15px rgba(0,0,0,0.2);
}

.logo-box img{
width:40px;
height:40px;
}

/* heading */

.title{
text-align:center;
margin-top:20px;
font-weight:bold;
}

.subtitle{
text-align:center;
color:gray;
margin-bottom:25px;
}

/* inputs */

.form-control{
padding:10px;
border-radius:8px;
}

/* button */

.login-btn{
width:100%;
background:#2f5fd7;
border:none;
padding:10px;
color:white;
font-weight:bold;
border-radius:8px;
margin-top:15px;
transition:0.3s;
}

.login-btn:hover{
background:#244cb3;
}

</style>

</head>

<body>

<div class="login-card">

<div class="logo-box">
<img src="/images/logo.png" alt="Logo" srcset="">
</div>

<h3 class="title">Welcome Back</h3>
<p class="subtitle">Sign in to your dashboard</p>

 <form action="/login" method="post" >

          <div class="mb-3">
              <label for="username" class="form-label">Username</label>
              <input type="text"
                     name="username"
                     id="username"
                     class="form-control"
                     placeholder="Enter username"
                     required>
          </div>

          <div class="mb-3">
              <label for="password" class="form-label">Password</label>
              <input type="password"
                     name="password"
                     id="password"
                     class="form-control"
                     placeholder="Enter password"
                     required>
          </div>

          <div class="d-grid">
              <button class="btn login-btn">Login</button>
          </div>

      </form>

</div>

</body>
</html>