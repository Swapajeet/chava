<% layout("layout/boilerplate") -%>

<style>
.page-title{
  font-weight:700;
}

.payment-card{
  border:none;
  border-radius:16px;
  box-shadow:0 10px 25px rgba(0,0,0,0.1);
}

.table thead{
  background:linear-gradient(135deg,#0d6efd,#6ea8fe);
  color:white;
}

.table tbody tr:hover{
  background:#f1f5ff;
}

.amount{
  font-weight:700;
  color:#198754;
}

.sidebar{
  min-height:100vh;
  background:#0f172a;
  color:white;
}
</style>

<div class="container-fluid">
<div class="row">

<!-- Sidebar -->
<div class="col-md-2 sidebar p-4">
  <%- include("../includes/sidebar.ejs") %>
</div>

<!-- Main -->
<div class="col-md-10 p-4">

<h2 class="page-title">💳 Payment History</h2>
<p class="text-muted">Track all income transactions</p>

<div class="card payment-card mt-3">
<div class="card-body">

<table class="table table-hover">

<thead>
<tr>
<th>Date</th>
<th>Amount</th>
<th>Membership ID</th>
<th>Notes</th>
</tr>
</thead>

<tbody>

<% memberships.forEach(m => { %>

  <% if (m.Payment) { %>

  <tr>
    <td>
      <%= new Date(m.Payment.paymentDate).toLocaleDateString() %>
    </td>

    <td class="amount">
      ₹<%= m.Payment.amount %>
    </td>

    <td>
      <%= m._id %>
    </td>

    <td>
      <%= m.Payment.notes %>
    </td>
  </tr>

  <% } %>

<% }) %>

</tbody>

</table>

</div>
</div>

</div>
</div>
</div>